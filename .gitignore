# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Pixel grid generation (large local files)
scripts/pixel-grid.sql
scripts/generate-pixel-grid.js
scripts/generate-pixel-grid.ts
scripts/worldcities.csv

# L2 grid chunks — regenerate with generate_l2_final.py
public/data/l2_chunks/*.geojson
!public/data/l2_chunks/_index.json

# Natural Earth shapefiles (use GeoJSON versions instead)
public/data/ne_50m_admin_1_states_provinces.*
public/data/ne_10m_admin_1_states_provinces.*

# Scratch debug scripts
scripts/grid-generation/check_*.py
scripts/grid-generation/debug*.py
scripts/grid-generation/diagnose_sjoin.py
scripts/grid-generation/download_admin1.py
scripts/grid-generation/download_ne10m.py
scripts/grid-generation/download_ne10m2.py
scripts/grid-generation/process_ne10m.py
scripts/grid-generation/test_admin1.py
scripts/grid-generation/verify*.py
